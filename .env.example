# ── DATABASE ──
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@cluster1.qgxaenk.mongodb.net/<db_name>?retryWrites=true&w=majority&appName=Cluster1

# ── EMAIL (Gmail) ──
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_TO=your-email@gmail.com

# ── ADMIN AUTH ──
ADMIN_EMAIL=admin@temidayo.com
ADMIN_PASSWORD_HASH=<generate-with-bcryptjs>
ADMIN_JWT_SECRET=<replace-with-a-random-long-secret>

# ── SITE / SEO ──
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Optional: Google Search Console HTML tag token (content value only)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-string



# Generate password hash:
# node -e "const b=require('bcryptjs'); console.log(b.hashSync('YourPassword',10))"

# Default admin password is: your chosen admin password
# CHANGE IT before deploying to production!
